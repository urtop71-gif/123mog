generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
}

model User {
  id               String         @id @default(cuid())
  email            String         @unique
  password         String
  name             String?
  age              Int?
  gender           String? // male, female
  height           Float? // cm
  weight           Float? // kg
  goalWeight       Float? // kg
  activityLevel    String? // sedentary, light, moderate, active, very_active
  bmr              Float?
  tdee             Float?
  dailyTarget      Float? // target daily calories
  proteinTarget    Float? // g
  fatTarget        Float? // g
  carbsTarget      Float? // g
  sodiumTarget     Float? // mg
  targetsManual    Boolean        @default(false) // if true, skip auto macro recalc
  waterTargetMl    Int            @default(2000)
  healthConditions String? // comma-separated: diabetes, high_cholesterol, hypertension
  onboardingDone   Boolean        @default(false)
  // sha256 hex digest of the personal access token used by the iOS Shortcuts
  // health-sync automation; null when no token has been issued. The raw token
  // is never stored - only shown once to the user at generation time.
  healthSyncTokenHash String?     @unique
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  meals            Meal[]
  customFoods      Food[]
  favorites        FavoriteFood[]
  weightLogs       WeightLog[]
  waterLogs        WaterLog[]
  exerciseLogs     ExerciseLog[]
}

model Food {
  id              String         @id @default(cuid())
  name            String
  nameEn          String?
  category        String // korean, japanese, western, seasian, singapore, general
  subcategory     String? // soup, rice, meat, side, noodle, etc.
  caloriesPer100g Float
  proteinPer100g  Float
  fatPer100g      Float
  carbsPer100g    Float
  sodiumPer100g   Float? // mg; null where not yet known
  healthTags      String? // comma-separated: ldl_good,ldl_bad,sugar_good,sugar_bad,etc.
  // null userId = shared global food; set = private custom food for that user
  userId          String?
  user            User?          @relation(fields: [userId], references: [id], onDelete: Cascade)
  isCustom        Boolean        @default(false)
  servings        FoodServing[]
  mealItems       MealItem[]
  favorites       FavoriteFood[]

  @@index([name])
  @@index([nameEn])
  @@index([userId])
}

model FoodServing {
  id           String @id @default(cuid())
  foodId       String
  food         Food   @relation(fields: [foodId], references: [id], onDelete: Cascade)
  unitName     String // 공기, 그릇, 접시, 개, 조각, 인분, 소, 중, 대, g, ml, ...
  gramsPerUnit Float // how many grams this serving unit equals

  @@index([foodId])
}

model Meal {
  id        String     @id @default(cuid())
  userId    String
  user      User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      DateTime   @default(now())
  mealType  String // breakfast, lunch, dinner, snack
  items     MealItem[]
  createdAt DateTime   @default(now())

  @@index([userId, date])
  @@index([userId, mealType])
}

model MealItem {
  id            String  @id @default(cuid())
  mealId        String
  meal          Meal    @relation(fields: [mealId], references: [id], onDelete: Cascade)
  foodId        String
  food          Food    @relation(fields: [foodId], references: [id])
  quantity      Float // e.g. 1.5
  unitName      String // e.g. 공기, g
  gramsPerUnit  Float // snapshot of the serving unit used
  totalGrams    Float // quantity * gramsPerUnit
  totalCalories Float
  totalProtein  Float
  totalFat      Float
  totalCarbs    Float
  totalSodium   Float? // mg; null where the food's sodium content isn't known

  @@index([mealId])
  @@index([foodId])
}

model FavoriteFood {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  foodId    String
  food      Food     @relation(fields: [foodId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, foodId])
  @@index([userId])
}

model WeightLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String // yyyy-MM-dd local date key
  weight    Float // kg
  createdAt DateTime @default(now())

  @@unique([userId, date])
  @@index([userId, date])
}

model WaterLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String // yyyy-MM-dd local date key
  ml        Int      @default(0)
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}

model ExerciseLog {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  date      String // yyyy-MM-dd local date key
  calories  Int      @default(0) // active/exercise energy burned that day
  source    String   @default("manual") // manual, healthkit
  updatedAt DateTime @updatedAt

  @@unique([userId, date])
  @@index([userId, date])
}
